# Backend environment template — KHÔNG commit secret thật.
# Copy file này thành `.env` (hoặc `.envbe` nếu giữ pattern hiện tại) rồi điền giá trị.

# ----- Runtime -----
NODE_ENV=development
PORT=5000

# ----- Database -----
MONGO_URI=mongodb://localhost:27017/zchess

# ----- JWT / Auth -----
# Phải khác nhau giữa access & refresh trong production.
JWT_SECRET=replace-with-32-byte-random
JWT_REFRESH_SECRET=replace-with-32-byte-random
ACCESS_TOKEN_EXPIRES=15m
REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_MAX_AGE_MS=31536000000
REFRESH_COOKIE_SAMESITE=lax

# ----- CORS -----
# URL chính thức của frontend trong môi trường này.
CLIENT_URL=http://localhost:5173
# Bổ sung các origin khác (cách nhau bằng dấu phẩy) — vd: https://admin.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# ----- Rate limit / Security -----
# Bật nếu chạy phía sau reverse proxy (Nginx/Cloudflare). Mặc định trust proxy = 1.

# ----- Logging / Audit -----
# Bật log JSON cho payroll audit (true/false).
PAYROLL_AUDIT_LOGS=false

# ----- Notification delivery -----
# (P1-4) Khi chuyển sang Redis/BullMQ.
# REDIS_URL=

# ----- Email (xác nhận mua khóa sau chuyển khoản) -----
# Không bắt buộc: thiếu SMTP_HOST thì chỉ gửi thông báo trong app, không gửi mail.
# CLIENT_URL dùng trong link trong email (mặc định http://localhost:5173).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Z CHESS <no-reply@example.com>"

# ----- Storage (uploads) -----
# Có thể trỏ ra S3-compatible khi triển khai prod.
UPLOADS_BASE_DIR=./uploads
